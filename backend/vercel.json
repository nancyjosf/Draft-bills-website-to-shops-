{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "server.js"
    },
    {
      "src": "/api/products(.*)",
      "dest": "server.js"
    },
    {
      "src": "/api/invoices(.*)",
      "dest": "server.js"
    }
  ]
}